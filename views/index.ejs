<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quera</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h1>Quera posts</h1>

    <% for(post of posts){ %>
        <div class="post">
            <h3 class="user">@<%= post.username %></h3>
            <h3 class="content"><%= post.content  %></h3>
            <a href="http://localhost:3000/posts/<%=post.id%>">show more</a>
            <a href="http://localhost:3000/posts/<%=post.id%>/edit">Edit post</a>

            <form method="POST" action="/posts/<%=post.id%>?_method=DELETE">
                <button>Delete</button>
            </form>
        </div>
    <% }%>

    <a href="http://localhost:3000/posts/new">Create Post</a>
</body>
</html>
